{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dart-digital-store-front",
  "compatibility_date": "2026-04-30",

  "pages_build_output_dir": "dist",

  "observability": {
    "enabled": true
  },

  "assets": {
    "not_found_handling": "single-page-application"
  },

  "compatibility_flags": [
    "nodejs_compat"
  ]
}